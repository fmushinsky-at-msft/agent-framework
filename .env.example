# Azure AI Foundry project endpoint
FOUNDRY_PROJECT_ENDPOINT="https://<your-account>.services.ai.azure.com/api/projects/<your-project>"

# Model deployment name — used for both intent classification and grounded answers.
AZURE_AI_MODEL_DEPLOYMENT_NAME="gpt-5.4-nano"

# Optional: reasoning controls for reasoning-capable models (e.g. GPT-5 family).
# Default OFF (empty) so nothing extra is sent and the current model can't break.
# Set these only for a reasoning model; lower values reduce latency.
# Effort: "minimal" (fastest) | "low" | "medium" | "high". Verbosity: "low" | "medium" | "high".
AZURE_AI_REASONING_EFFORT="minimal"
AZURE_AI_VERBOSITY="low"

# Azure AI Search configuration for production knowledge retrieval
AZURE_SEARCH_ENDPOINT="https://<your-search-service>.search.windows.net"
AZURE_SEARCH_INDEX_NAME="<your-index-name>"
# Optional: API key auth. If omitted, DefaultAzureCredential is used.
AZURE_SEARCH_API_KEY=""

# Agent mode: "basic" (single agent with tools) or "workflow" (multi-agent pipeline)
AGENT_MODE="basic"

# Observability settings (optional)
ENABLE_INSTRUMENTATION=true
ENABLE_SENSITIVE_DATA=true
