### Follow-up turn in same conversation
# 1) Run the previous request first.
# 2) Copy response.conversation_id and paste below.
POST http://localhost:8088/responses HTTP/1.1
Content-Type: application/json

{
	"message": "compare them",
	"agentid": "orchestrator",
	"conversation_id": "resp_03fced1cc6dca199006a1ef37759e881939e8d4e2e3959268c",
	"parameters": {
		"user_id": "JDOE",
		"username": "John Doe"
	}
}

